---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
  class?: string;
}

const { href, external, underline = true, class: className, ...rest } = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class={cn("inline-block decoration-decoration hover:decoration-accent text-current hover:text-fg-strong transition-colors duration-300 ease-in-out", underline && "underline underline-offset-2", className)}
  {...rest}>
  <slot/>{external && <span class="sr-only"> (opens in new window)</span>}
</a>
