---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ContentCard from "@components/ContentCard.astro";
import ExcerptEntry from "@components/ExcerptEntry.astro";
import { getBlogEntryProps, getBriefEntryProps, getProjectCardProps } from "@lib/contentCardHelpers";
import Link from "@components/Link.astro";
import { getPublishedCollection } from "@lib/collections";
import { SITE, HOME, SOCIALS } from "@consts";
import { getHomeOGData } from "@lib/opengraph";

const blog = await getPublishedCollection("blog", SITE.NUM_POSTS_ON_HOMEPAGE);
const projects = await getPublishedCollection("projects", SITE.NUM_PROJECTS_ON_HOMEPAGE);
const briefs = await getPublishedCollection("briefs", SITE.NUM_BRIEFS_ON_HOMEPAGE);

const ogData = getHomeOGData(
  Astro.url.toString(),
  Astro.site?.toString() || ""
);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION} ogData={ogData}>
  <Container>
    <h1 class="sr-only">Dispatches</h1>

    <p class="intro-lede">
      <em>Dispatches</em> is where I publish my technical writing. During this initial phase, much of the content will be "refurbished-and-expanded": older personal notes or explanations, updated and expanded where necessary. Expect a focus on Swift, lower-level iOS work, and—as of late—agentic coding assistants.
    </p>

    <section class="feed-section">
      <div class="feed-head">
        <h2 class="feed-eyebrow">Latest posts</h2>
        <Link href="/blog" class="feed-seeall">See all posts</Link>
      </div>
      <ul class="ex-feed">
        {blog.map(post => (
          <li>
            <ExcerptEntry kindLabel="Blog" {...getBlogEntryProps(post)} />
          </li>
        ))}
      </ul>
    </section>

    <section class="feed-section">
      <div class="feed-head">
        <h2 class="feed-eyebrow">Recent briefs</h2>
        <Link href="/briefs" class="feed-seeall">See all briefs</Link>
      </div>
      <ul class="ex-feed">
        {briefs.map(brief => (
          <li>
            <ExcerptEntry {...getBriefEntryProps(brief, true)} />
          </li>
        ))}
      </ul>
    </section>

    <section class="feed-section">
      <div class="feed-head">
        <h2 class="feed-eyebrow">Recent projects</h2>
        <Link href="/projects" class="feed-seeall">See all projects</Link>
      </div>
      <ul class="flex flex-col gap-4">
        {projects.map(project => (
          <li>
            <ContentCard {...getProjectCardProps(project, { maxLines: 2 })} />
          </li>
        ))}
      </ul>
    </section>

    <section class="feed-section space-y-4">
      <div class="feed-head">
        <h2 class="feed-eyebrow">Let's connect</h2>
      </div>
      <p>Here's how to get in touch:</p>
      <ul class="flex flex-wrap gap-2">
        {SOCIALS.map(SOCIAL => (
          <li class="flex gap-x-2 text-nowrap">
            <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
              {SOCIAL.NAME}
            </Link>
          </li>
        ))}
      </ul>
    </section>
  </Container>
</PageLayout>
