---
import { render, type CollectionEntry } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import { getPublishedCollection } from "@lib/collections";
import BackToPrev from "@components/BackToPrev.astro";
import { getPostOGData } from "@lib/opengraph";
import { renderInlineMarkdown } from "@lib/markdown";

export async function getStaticPaths() {
  const posts = await getPublishedCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);

const ogData = getPostOGData(post, Astro.url.toString(), Astro.site?.toString() || "");
const renderedTitle = renderInlineMarkdown(post.data.title);

// Opt-in Tufte layout: a wider column with footnotes floated into a
// right-margin gutter (see src/lib/rehype-sidenotes.mjs + `.post-blog`).
const useTufte = post.data.sidenotes === true;
const wrapperClass = useTufte ? "mx-auto max-w-[880px] px-5" : "mx-auto max-w-[var(--container)] px-5";
---

<PageLayout title={post.data.title} description={post.data.description} ogData={ogData}>
  <div class={wrapperClass}>
    <div>
      <BackToPrev href="/blog">
        Back to blog
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body ?? "")}
        </div>
      </div>
      <h1 class="text-2xl font-semibold text-fg-strong" set:html={renderedTitle}></h1>
    </div>
    <article class={useTufte ? "post-blog" : undefined}>
      <Content />
    </article>
  </div>
</PageLayout>
