      "--text-4xl": "font",
      "--leading-tight": "font",
      "--leading-snug": "font",
      "--leading-normal": "font",
      "--leading-relaxed": "font",
      "--leading-loose": "font",
      "--weight-regular": "font",
      "--weight-medium": "font",
      "--weight-semibold": "font",
      "--weight-bold": "font",
      "--radius-sm": "radius",
      "--radius": "radius",
      "--radius-lg": "radius",
      "--radius-full": "radius",
      "--container": "spacing",
      "--header-h": "spacing",
      "--page-py": "spacing",
      "--ease-in-out": "other",
