{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "explorations/**",
              "og-final.jsx",
              "ui_kits/blog/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Source Serif 4|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Source Serif 4, Inter, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-soft",
      "--bg",
      "--bg-elevated",
      "--bg-hover",
      "--border",
      "--border-hover",
      "--container",
      "--decoration",
      "--decoration-hover",
      "--dur-base",
      "--dur-fast",
      "--ease-in-out",
      "--fg",
      "--fg-muted",
      "--fg-strong",
      "--focus-ring",
      "--font-mono",
      "--font-sans",
      "--font-serif",
      "--header-h",
      "--ink",
      "--leading-loose",
      "--leading-normal",
      "--leading-relaxed",
      "--leading-snug",
      "--leading-tight",
      "--moon",
      "--night",
      "--page-py",
      "--paper",
      "--plum-300",
      "--plum-700",
      "--radius",
      "--radius-full",
      "--radius-lg",
      "--radius-sm",
      "--stone-100",
      "--stone-900",
      "--text-2xl",
      "--text-3xl",
      "--text-4xl",
      "--text-base",
      "--text-lg",
      "--text-sm",
      "--text-xl",
      "--text-xs",
      "--weight-bold",
      "--weight-medium",
      "--weight-regular",
      "--weight-semibold"
    ],
    "tokenKinds": {
      "--ink": "color",
      "--night": "color",
      "--paper": "color",
      "--moon": "color",
      "--plum-700": "color",
      "--plum-300": "color",
      "--stone-100": "color",
      "--stone-900": "color",
      "--bg": "color",
      "--bg-elevated": "color",
      "--bg-hover": "color",
      "--fg": "color",
      "--fg-strong": "color",
      "--fg-muted": "color",
      "--border": "color",
      "--border-hover": "color",
      "--decoration": "color",
      "--decoration-hover": "color",
      "--accent": "color",
      "--accent-soft": "color",
      "--focus-ring": "color",
      "--font-sans": "font",
      "--font-serif": "font",
      "--font-mono": "font",
      "--text-xs": "font",
      "--text-sm": "font",
      "--text-base": "font",
      "--text-lg": "font",
      "--text-xl": "font",
      "--text-2xl": "font",
